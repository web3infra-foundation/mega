# Generated by Cargo
# will have compiled files and executables
target
**/target/
# Keep Cargo.lock in build context for reproducible + cache-friendly builds.

moon
moon/**

# Not in workspace image; local targets/deps can be very large and slow `docker build` context transfer.
tools
tools/**

docs

scripts

tests

# These are backup files generated by rustfmt
**/*.rs.bk

# node
**/node_modules/
**/.next/
**/.turbo/
**/dist/
**/build/
**/out/
**/coverage/
**/.cargo/

# IDE configurations
.idea
.vscode
.zed

# Mac
.DS_Store

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.VSCodeCounter

# zmt agent data file
ztm_agent.db
ztm_agent_db*

# buck2 out
buck-out

# local docker build cache (huge, never needed in image)
.buildx-cache
.buildx-cache/**
.buildx-cache*/

# Dockderfile
docker

# git / ci metadata (not needed for docker builds, reduces build context)
.git/
.github/

# logs
*.log
